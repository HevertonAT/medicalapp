            <Button colorScheme="blue" mr={3} onClick={handleSave}>{isEditing ? 'Salvar Alterações' : 'Finalizar Cadastro'}</Button>
            <Button onClick={onClose} variant="ghost">Cancelar</Button>
          </ModalFooter>
        </ModalContent>
      </Modal>
    </Box>
  );
}
